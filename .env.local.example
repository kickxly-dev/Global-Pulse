# NewsAPI Configuration
# Get your API key from: https://newsapi.org/register
NEXT_PUBLIC_NEWS_API_KEY=your_newsapi_key_here

# Alternative: GDELT API (no key required)
# NEXT_PUBLIC_USE_GDELT=true

# Alternative: EventRegistry API
# Get your API key from: https://eventregistry.org/register
# NEXT_PUBLIC_EVENTREGISTRY_API_KEY=your_eventregistry_key_here

# Map Configuration (Choose one)
# Mapbox (recommended for best features)
# Get your token from: https://account.mapbox.com/auth/signup/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Alternative: Use OpenStreetMap (no token required)
NEXT_PUBLIC_USE_OPENSTREETMAP=true

# Web Push Notification Keys
# Generate keys using: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:your-email@example.com

# Optional: Custom News Sources
NEXT_PUBLIC_CUSTOM_RSS_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/World.xml

# Optional: Weather API for location-based alerts
# Get your key from: https://openweathermap.org/api
NEXT_PUBLIC_WEATHER_API_KEY=your_openweather_key_here

# Application URL (update for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Optional - for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/globalpulse

# Redis Cache (Optional - for production)
# REDIS_URL=redis://localhost:6379
